{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(docker compose:*)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_console_messages"
    ],
    "deny": [
      "Read(./**/.git/**)",
      "Read(./Notzien (Obsidian)/.obsidian/**)",
      "Read(./**/__pycache__/**)",
      "Read(./**/.pytest_cache/**)",
      "Read(./**/node_modules/**)",
      "Read(./**/*.png)",
      "Read(./**/*.jpg)",
      "Read(./**/*.jpeg)",
      "Read(./**/*.zip)",
      "Read(./Mobile Picking und Voice Assistant/.env)",
      "Read(./Mobile Picking und Voice Assistant/infrastructure/certs/*.pem)",
      "Read(./Mobile Picking und Voice Assistant/infrastructure/certs/*.key)",
      "Read(./Mobile Picking und Voice Assistant/infrastructure/certs/*.crt)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log_obsidian_change.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce_completion.py\"",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
