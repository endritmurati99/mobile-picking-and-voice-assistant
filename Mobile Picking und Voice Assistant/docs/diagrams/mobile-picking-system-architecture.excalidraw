      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "PWA → FastAPI `/confirm-line` → Claim/Idempotency-Prüfung\n→ Odoo-Write → asynchrones `pick-confirmed` an n8n.\nPicking bleibt fachlich gültig, auch wenn n8n degradiert.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PWA → FastAPI `/confirm-line` → Claim/Idempotency-Prüfung\n→ Odoo-Write → asynchrones `pick-confirmed` an n8n.\nPicking bleibt fachlich gültig, auch wenn n8n degradiert.",
      "lineHeight": 1.2,
      "fontWeight": "400"
    },
