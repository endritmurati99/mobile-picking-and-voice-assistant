    {
      "id": "text_070",
      "type": "text",
      "x": 58,
      "y": 850,
      "width": 1054,
      "height": 35.1,
      "angle": 0,
      "strokeColor": "#4b5563",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 69790,
      "version": 1,
      "versionNonce": 864150,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "1. Odoo bleibt System of Record.  2. FastAPI ist die einzige App-API für die PWA.  3. n8n liegt nicht im normalen Voice-Hot-Path.\n4. n8n schreibt fachlich nur über interne FastAPI-Callbacks zurück.  5. Touch bleibt Fallback; Voice darf Picking nicht blockieren.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Odoo bleibt System of Record.  2. FastAPI ist die einzige App-API für die PWA.  3. n8n liegt nicht im normalen Voice-Hot-Path.\n4. n8n schreibt fachlich nur über interne FastAPI-Callbacks zurück.  5. Touch bleibt Fallback; Voice darf Picking nicht blockieren.",
      "lineHeight": 1.25,
      "fontWeight": "400"
    },
