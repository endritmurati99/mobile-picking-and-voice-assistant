# .env.example — Kopieren nach .env und Werte ausfüllen
# NIEMALS .env committen!

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=odoo
POSTGRES_PASSWORD=HIER_SICHERES_PASSWORT_SETZEN
POSTGRES_HOST_PORT=5433

# ── Odoo ─────────────────────────────────────────────────────
ODOO_DB=picking
ODOO_USER=admin
ODOO_API_KEY=WIRD_NACH_ODOO_SETUP_GENERIERT

# ── n8n ──────────────────────────────────────────────────────
# WICHTIG: Vor erstem Start generieren und SICHER aufbewahren!
# Verlust = alle n8n Credentials unwiederbringlich verloren.
# Generieren: openssl rand -hex 32
N8N_ENCRYPTION_KEY=HIER_GENERIEREN

# ── Netzwerk ─────────────────────────────────────────────────
# LAN-IP des Docker-Hosts (z.B. 192.168.1.100)
LAN_HOST=192.168.1.100

# ── n8n Webhook ──────────────────────────────────────────────
N8N_WEBHOOK_SECRET=HIER_GENERIEREN
N8N_WEBHOOK_PATH_QUALITY_ALERT_CREATED=quality-alert-created
N8N_WEBHOOK_PATH_VOICE_EXCEPTION_QUERY=voice-exception-query
N8N_WEBHOOK_PATH_SHORTAGE_REPORTED=shortage-reported
N8N_WEBHOOK_PATH_PICK_CONFIRMED=pick-confirmed

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info

# Mobile workflow hardening
MOBILE_CLAIM_TTL_SECONDS=120
MOBILE_CLAIM_HEARTBEAT_SECONDS=30
MOBILE_IDEMPOTENCY_TTL_SECONDS=86400
MOBILE_HEADER_GRACE_MODE=true
N8N_CALLBACK_SECRET=HIER_GENERIEREN
N8N_SYNC_TIMEOUT_MS=7000
N8N_CIRCUIT_BREAKER_FAILURES=3
N8N_CIRCUIT_BREAKER_OPEN_SECONDS=60
OBSIDIAN_PATH=../Notzien
QUALITY_ALERT_EMAIL_FROM=
QUALITY_ALERT_EMAIL_TO=
