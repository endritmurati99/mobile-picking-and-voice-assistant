<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="quality_alert_view_kanban" model="ir.ui.view">
        <field name="name">quality.alert.custom.kanban</field>
        <field name="model">quality.alert.custom</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column">
                <field name="name"/>
                <field name="priority"/>
                <field name="product_id"/>
                <field name="user_id"/>
                <field name="stage_id"/>
                <field name="ai_disposition"/>
                <templates>
                    <t t-name="card">
                        <field name="priority" widget="priority"/>
                        <field name="name"/>
                        <field name="product_id"/>
                        <field name="ai_disposition"/>
                        <div class="o_kanban_record_bottom">
                            <field name="user_id"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="quality_alert_view_form" model="ir.ui.view">
        <field name="name">quality.alert.custom.form</field>
        <field name="model">quality.alert.custom</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_in_progress"
                            string="In Bearbeitung"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_set_done"
                            string="Erledigt"
                            type="object"
                            class="btn-primary"/>
                    <field name="stage_id" widget="statusbar" clickable="1"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="priority" widget="priority"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="picking_id"/>
                            <field name="product_id"/>
                            <field name="location_id"/>
                            <field name="lot_id"/>
                        </group>
                    </group>

                    <div class="row mt16">
                        <div class="col-md-6">
                            <group string="Picker-Meldung" name="description_box">
                                <field name="description" nolabel="1"
                                       placeholder="Problembeschreibung..." readonly="1"/>
                            </group>
                            <group string="Fotos" name="photos_box">
                                <field name="photo_gallery" nolabel="1"/>
                            </group>
                        </div>

                        <div class="col-md-6">
                        <group string="Systembewertung" name="auto_assessment">
                            <field name="ai_evaluation_status"
                                   string="Analyse-Status"
                                   widget="badge"
                                   readonly="1"
                                   decoration-info="ai_evaluation_status == 'pending'"
                                   decoration-success="ai_evaluation_status == 'completed'"
                                   decoration-danger="ai_evaluation_status == 'failed'"/>
                            <field name="ai_disposition"
                                   string="Einstufung"
                                   widget="badge"
                                   readonly="1"
                                   decoration-danger="ai_disposition == 'scrap'"
                                   decoration-warning="ai_disposition == 'rework' or ai_disposition == 'quarantine'"
                                   decoration-success="ai_disposition == 'sellable'"/>
                            <field name="ai_recommended_action" string="Empfohlene Aktion" readonly="1"
                                   invisible="not ai_recommended_action"/>
                            <field name="ai_last_analyzed_at" string="Analysiert am" readonly="1"
                                   invisible="not ai_last_analyzed_at"/>
                            <field name="ai_failure_reason" readonly="1"
                                   invisible="ai_evaluation_status != 'failed'"/>
                        </group>
                        </div>
                    </div>

                    <!-- Telemetrie: im Backend gespeichert, nicht im Sichtfeld des Operators -->
                    <group invisible="True">
                        <field name="ai_confidence"/>
                        <field name="ai_enhanced_description"/>
                        <field name="ai_photo_analysis"/>
                        <field name="ai_summary"/>
                        <field name="ai_provider"/>
                        <field name="ai_model"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="quality_alert_view_list" model="ir.ui.view">
        <field name="name">quality.alert.custom.list</field>
        <field name="model">quality.alert.custom</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_id"/>
                <field name="picking_id"/>
                <field name="priority"/>
                <field name="stage_id"/>
                <field name="ai_disposition" string="Einstufung"/>
                <field name="ai_evaluation_status" widget="badge"
                       decoration-info="ai_evaluation_status == 'pending'"
                       decoration-success="ai_evaluation_status == 'completed'"
                       decoration-danger="ai_evaluation_status == 'failed'"
                       string="Analyse-Status"
                       optional="show"/>
                <field name="ai_last_analyzed_at" string="Analysiert am" optional="show"/>
            </list>
        </field>
    </record>

    <record id="quality_alert_action" model="ir.actions.act_window">
        <field name="name">Quality Alerts</field>
        <field name="res_model">quality.alert.custom</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_quality_root" name="Qualität" web_icon="quality_alert_custom,static/description/icon.png" sequence="25"/>
    <menuitem id="menu_quality_alerts" name="Quality Alerts"
              parent="menu_quality_root" action="quality_alert_action" sequence="10"/>
</odoo>
