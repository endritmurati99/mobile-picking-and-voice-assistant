{
  "name": "Daily Picking Report",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 8 * * 1-5" }]
        }
      },
      "name": "Schedule (Mo-Fr 08:00)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "content": "=📊 Täglicher Picking-Report\n\nDatum: {{ $now.format('dd.MM.yyyy') }}\n\nHier können Odoo-Abfragen für offene Pickings, abgeschlossene Pickings und offene Quality Alerts ergänzt werden."
      },
      "name": "Generate Report",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [450, 300]
    }
  ],
  "connections": {
    "Schedule (Mo-Fr 08:00)": {
      "main": [
        [{ "node": "Generate Report", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "reporting" }]
}
